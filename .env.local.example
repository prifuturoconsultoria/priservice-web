# Azure AD OAuth Configuration
NEXT_PUBLIC_AZURE_TENANT_ID=your-tenant-id-here
NEXT_PUBLIC_AZURE_CLIENT_ID=your-client-id-here
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/auth/callback

# Backend API
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# JWT Secret (must match Spring Boot's jwt.secret)
# ⚠️ IMPORTANT: Copy this value from your Spring Boot application.properties
# This is used to verify JWT signatures and prevent token forgery
JWT_SECRET=your-jwt-secret-from-spring-boot

# Supabase (if still using for other features)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
